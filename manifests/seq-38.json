{
  "seq": 38,
  "mode": "apply",
  "note": "seq=38: RAM-safety dial-back -- pool threads 48->20 (frees memory so PG can never OOM). Lifeline-first.",
  "steps": [
    {
      "type": "noop",
      "note": "seq=38: DIAL BACK pool concurrency 48->20 threads/proc (box was at 97% RAM -> OOM risk to Postgres). 32 procs x20 = 640 lanes. Target <=80% RAM. ~1200-1400/min PG-safe > 1538 at 97%."
    },
    {
      "type": "write_file",
      "path": "/etc/systemd/system/atlas-enrich-pool@.service",
      "content": "[Unit]\nDescription=ATLAS threaded enrichment pool worker (instance %i; RAM-safe)\nAfter=network-online.target postgresql.service\nWants=network-online.target\n\n[Service]\nType=simple\nEnvironment=ATLAS_WORKER_INSTANCE=%i\nEnvironment=ATLAS_POOL_CONCURRENCY=20\nEnvironment=ATLAS_POOL_CLAIM=40\nEnvironment=ATLAS_DB_ENV=/etc/atlas/db.env\nEnvironment=ATLAS_AUTOPULL_CONF=/etc/atlas/autopull.env\nExecStart=/opt/atlas/venv/bin/python /opt/atlas/enrich/atlas_enrich_pool.py --loop\nRestart=always\nRestartSec=5\nNice=10\nIOSchedulingClass=idle\n\n[Install]\nWantedBy=multi-user.target\n"
    },
    {
      "type": "systemd",
      "action": "daemon-reload",
      "unit": "atlas-enrich-pool@.service"
    },
    {
