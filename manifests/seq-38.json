    {
      "type": "write_file",
      "path": "/etc/systemd/system/atlas-enrich-pool@.service",
      "content": "[Unit]\nDescription=ATLAS enrichment pool worker (instance %i; PG-SAFE)\nAfter=network-online.target postgresql.service\nWants=network-online.target\n\n[Service]\nType=simple\nEnvironment=ATLAS_WORKER_INSTANCE=%i\nEnvironment=ATLAS_POOL_CONCURRENCY=16\nEnvironment=ATLAS_POOL_CLAIM=32\nEnvironment=ATLAS_DB_ENV=/etc/atlas/db.env\nEnvironment=ATLAS_AUTOPULL_CONF=/etc/atlas/autopull.env\nExecStart=/opt/atlas/venv/bin/python /opt/atlas/enrich/atlas_enrich_pool.py --loop\nRestart=always\nRestartSec=10\nNice=10\nIOSchedulingClass=idle\n\n[Install]\nWantedBy=multi-user.target\n"
    },
    {
      "type": "systemd",
      "action": "daemon-reload",
      "unit": "atlas-enrich-pool@.service"
    },
